---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/BlogCard.astro';

// Every post is listed — publishing is gated by the merge (beta auto-deploys,
// prod is a manual dispatch), not by a frontmatter flag.
const all = await getCollection('blog');

// Order posts within a project as a readable set: series, then order, then date.
const withinProject = (a, b) => {
  const sa = a.data.series ?? '';
  const sb = b.data.series ?? '';
  if (sa !== sb) return sa.localeCompare(sb);
  const oa = a.data.order ?? Number.POSITIVE_INFINITY;
  const ob = b.data.order ?? Number.POSITIVE_INFINITY;
  if (oa !== ob) return oa - ob;
  return a.data.pubDate.valueOf() - b.data.pubDate.valueOf();
};

// Meta / blog-level posts (no project) surface at the top, newest first.
const metaPosts = all
  .filter((p) => !p.data.project)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group the rest by project; order the groups by their most-recent post so the
// active project leads without hardcoding any one project as primary.
const byProject = new Map();
for (const post of all) {
  if (!post.data.project) continue;
  const list = byProject.get(post.data.project) ?? [];
  list.push(post);
  byProject.set(post.data.project, list);
}
const projectGroups = [...byProject.entries()]
  .map(([project, posts]) => {
    posts.sort(withinProject);
    const latest = Math.max(...posts.map((p) => p.data.pubDate.valueOf()));
    return { project, posts, latest };
  })
  .sort((a, b) => b.latest - a.latest);

const seriesLabel = (post) =>
  post.data.series
    ? `${post.data.series}${post.data.order != null ? ` · #${post.data.order}` : ''}`
    : null;
---

<BaseLayout title="Blog" description="Engineering writing from SHUKE-LABS — each project tells its own story.">
  <Nav />
  <main class="flex-1">
    <section class="mx-auto max-w-3xl px-6 py-16">
      <h1 class="text-3xl font-bold tracking-tight text-ink">Blog</h1>
      {
        metaPosts.length === 0 && projectGroups.length === 0 ? (
          <p class="mt-6 text-muted">No posts yet.</p>
        ) : (
          <div class="mt-8 space-y-12">
            {metaPosts.length > 0 && (
              <ul class="divide-y divide-line border-t border-line">
                {metaPosts.map((post) => (
                  <BlogCard post={post} heading="h2" />
                ))}
              </ul>
            )}
            {projectGroups.map((group) => (
              <section>
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">{group.project}</h2>
                <ul class="mt-4 divide-y divide-line border-t border-line">
                  {group.posts.map((post) => (
                    <BlogCard post={post} heading="h3" series={seriesLabel(post)} />
                  ))}
                </ul>
              </section>
            ))}
          </div>
        )
      }
    </section>
  </main>
  <Footer />
</BaseLayout>
