---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  // my-ai-team has a dedicated hand-composed page at products/my-ai-team.astro.
  const products = (await getCollection('products')).filter((p) => p.id !== 'my-ai-team');
  return products.map((product) => ({
    params: { slug: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { title, description, tagline, commercial, github, free, icon_emoji, icon_image } =
  product.data;
const { Content } = await render(product);
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="flex-1">
    <article class="mx-auto max-w-3xl px-6 pt-6 pb-12">
      <a href="/" aria-label="Back to home" class="text-sm text-muted hover:text-ink transition-colors">&larr;</a>

      <header class="mt-6 border-b border-line pb-8">
        <div class="flex items-center gap-3">
          {icon_emoji && <span class="text-3xl leading-none" aria-hidden="true">{icon_emoji}</span>}
          {icon_image && <img src={`/images/${icon_image}`} alt="" width="36" height="36" class="h-9 w-9" />}
          <h1 class="text-3xl font-bold tracking-tight text-ink">{title}</h1>
        </div>
        <p class="mt-3 text-lg text-muted">{description}</p>
        {tagline && <p class="mt-1 text-accent font-medium">{tagline}</p>}

        <div class="mt-5 flex flex-wrap items-center gap-3 text-sm">
          {commercial && (
            <span class="rounded-full bg-accent-soft px-3 py-1 font-medium text-accent">Commercial license</span>
          )}
          {free && (
            <span class="rounded-full bg-accent-soft px-3 py-1 font-medium text-accent">Open source</span>
          )}
          {github && (
            <a
              href={github}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center rounded-lg border border-line px-3 py-1 text-ink hover:border-accent hover:text-accent transition-colors"
              >View on GitHub</a
            >
          )}
        </div>
      </header>

      <div class="prose mt-8">
        <Content />
      </div>

      {
        commercial && (
          <div class="mt-10 rounded-2xl border border-line bg-surface-soft p-6 sm:p-8">
            <h2 class="text-xl font-bold text-ink">Get {title}</h2>
            <p class="mt-2 text-muted">
              Included in the bundle — $5/mo or $49.99/yr (USD).
            </p>
            <a
              href="/pricing"
              class="mt-5 inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
            >
              See pricing &amp; get the bundle
            </a>
          </div>
        )
      }
    </article>
  </main>
  <Footer />
</BaseLayout>
