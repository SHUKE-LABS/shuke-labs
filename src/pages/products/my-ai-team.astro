---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { bundlePriceSummary } from '../../config/pricing';

const title = 'My AI Team';
const description = 'AI teammates, not AI tools. You decide. Agent delivers.';

// One line per mode, condensed verbatim from the framework's docs/session-modes.md.
const modes = [
  {
    name: 'team',
    line: 'Three-agent relay: planner writes the plan, reviewer gates it, developer implements, reviewer reviews and merges.',
  },
  {
    name: 'duo',
    line: "Two agents: dev owns planning + implementation, an independent reviewer authored neither the plan nor the code.",
  },
  {
    name: 'adhoc',
    line: 'Single agent owns the full cycle — planning, implementation, review, merge, and notification.',
  },
  {
    name: 'explore',
    line: 'Open-ended investigation; no repo required, no delivery code — crystallises tickets that hand off to delivery.',
  },
  {
    name: 'audit',
    line: 'Quality auditor for the repo; files structured triage tickets about merged work, never writes delivery code.',
  },
  {
    name: 'caucus',
    line: 'Two peer agents deliberate — a proposer opens a position, a challenger stress-tests it — converging on tickets.',
  },
  {
    name: 'live',
    line: 'Bare-bones single agent in the current directory with the native REPL — no relay, issue queue, or PR workflow.',
  },
];

// The autonomous loop — the page's single diagram. Forward path runs
// Human → Explorer → Planner → [plan review] → Developer → [review] → [CI] →
// Merge; merge re-arms the cycle, the Auditor files new tickets that feed back
// to the Planner, and Deploy branches off as optional. `gate`/`ci` nodes are
// the trust checkpoints that separate guarded teammates from unguarded
// automation; `agent: true` stages are the automated delivery.
const loop = [
  { kind: 'stage', who: 'Human', tag: 'kickoff', note: 'You bring the goal — a rough idea, a bug, a feature.' },
  { kind: 'stage', who: 'Explorer', agent: true, note: 'Refines the idea into a self-standing ticket.' },
  { kind: 'stage', who: 'Planner', agent: true, note: 'Drafts the approach; the plan names real files and steps.' },
  { kind: 'gate', who: 'Plan review', note: 'A reviewer signs off before a line of code is written.' },
  { kind: 'stage', who: 'Developer', agent: true, note: 'Implements on a branch and opens the PR.' },
  { kind: 'gate', who: 'Review', note: 'A reviewer signs off again before merge.' },
  { kind: 'ci', note: 'CI runs the suite — green merges, red reopens the Developer.' },
  { kind: 'stage', who: 'Merge', agent: true, note: 'Squashed to main; the cycle re-arms for the next ticket.' },
  { kind: 'deploy', who: 'Deploy', note: 'Optional — ship the merged change to staging or production.' },
];

const differentiators = [
  {
    heading: 'Custom protocols, per repo',
    body: 'Layer repo-specific rules on top of the standard agent constitutions. Each project teaches the team its own conventions, verification steps, and boundaries.',
    diagram: ['standard constitution', '+ CLAUDE.md', '+ agents/*.md', '= this repo’s rules'],
  },
  {
    heading: 'Fresh context per ticket',
    body: 'Context is cleared between tickets. A reviewer re-reads the next diff cold, with none of the implementer’s heavy state carried over — so review stays independent.',
    diagram: ['ticket #1 → done', '── context cleared ──', 'ticket #2 → fresh start'],
  },
  {
    heading: 'Autonomous conflict resolution',
    body: 'When agents disagree on design or direction, caucus convenes two peers to deliberate to a concrete conclusion — resolving locally instead of escalating to you.',
    diagram: ['proposer  ⇄  challenger', 'deliberate', 'conclusion → ticket'],
  },
  {
    heading: 'Auto-pickup of the next ticket',
    body: 'After a merge the system re-arms itself: it resolves the next ready ticket and starts again — finishing one thing and picking up the next without being re-invoked.',
    diagram: ['merge #142', '→ next-work', '→ implement #143'],
  },
];
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="flex-1">
    <!-- Hero -->
    <section class="mx-auto max-w-5xl px-6 pt-6 pb-16 sm:pt-8 sm:pb-20">
      <a href="/" aria-label="Back to home" class="text-sm text-muted hover:text-ink transition-colors">&larr;</a>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-ink">
        AI teammates, not AI tools.
      </h1>
      <p class="mt-4 text-xl sm:text-2xl font-medium text-accent">You decide. Agent delivers.</p>
    </section>

    <!-- The autonomous loop — the page's focal element -->
    <section class="mx-auto max-w-5xl px-6 pb-16">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-muted">The autonomous loop</h2>

      {/* Forward path: stages + trust gates, connected as one flow. */}
      <div class="mt-6 flex flex-col sm:flex-row sm:flex-wrap sm:items-stretch sm:gap-y-3">
        {
          loop.map((node, i) => (
            <>
              {i > 0 && (
                <div
                  class="flex items-center justify-center py-2 text-2xl text-muted sm:px-3 sm:py-0"
                  aria-hidden="true"
                >
                  <span class="sm:hidden">{node.kind === 'deploy' ? '⇣' : '↓'}</span>
                  <span class="hidden sm:inline">{node.kind === 'deploy' ? '⇢' : '→'}</span>
                </div>
              )}

              {/* stage */}
              {node.kind === 'stage' && (
                <div class="rounded-2xl border border-line bg-surface p-6 sm:min-w-[12rem] sm:flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="text-lg font-semibold text-ink">{node.who}</span>
                    {node.tag && (
                      <span class="rounded-full bg-accent-soft px-2.5 py-0.5 font-mono text-xs font-medium text-accent">
                        {node.tag}
                      </span>
                    )}
                    {node.agent && (
                      <span class="rounded-full bg-accent-soft px-2.5 py-0.5 font-mono text-xs font-medium text-accent">
                        agent
                      </span>
                    )}
                  </div>
                  <p class="mt-2 text-sm text-muted leading-relaxed">{node.note}</p>
                </div>
              )}

              {/* trust gate — accent checkpoint, ✓ marks the sign-off */}
              {node.kind === 'gate' && (
                <div class="rounded-xl border border-accent bg-accent-soft px-5 py-4 sm:min-w-[12rem]">
                  <div class="font-mono text-sm font-semibold text-accent">✓ {node.who}</div>
                  <p class="mt-1 text-sm text-muted leading-relaxed">{node.note}</p>
                </div>
              )}

              {/* CI decision — green/red fork, stacked inline so it reads on mobile */}
              {node.kind === 'ci' && (
                <div class="rounded-xl border border-line bg-surface p-5 sm:min-w-[12rem]">
                  <span class="font-mono text-base font-semibold text-ink">CI</span>
                  <div class="mt-2 space-y-1 font-mono text-xs">
                    <div class="text-accent">✓ green → merge</div>
                    <div class="text-muted">✗ red → Developer</div>
                  </div>
                </div>
              )}

              {/* deploy — optional dashed branch off merge */}
              {node.kind === 'deploy' && (
                <div class="rounded-2xl border border-dashed border-line bg-surface p-6 sm:min-w-[12rem] sm:flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="text-lg font-semibold text-ink">{node.who}</span>
                    <span class="rounded-full bg-accent-soft px-2.5 py-0.5 font-mono text-xs font-medium text-accent">
                      optional
                    </span>
                  </div>
                  <p class="mt-2 text-sm text-muted leading-relaxed">{node.note}</p>
                </div>
              )}
            </>
          ))
        }
      </div>

      {/* Loop closure: merge re-arms the cycle; the Auditor feeds new tickets back to the Planner. */}
      <div class="mt-6 flex items-center gap-3 rounded-xl border border-dashed border-line bg-surface-soft p-5">
        <span class="text-2xl text-accent" aria-hidden="true">↻</span>
        <p class="font-mono text-sm text-muted leading-relaxed">
          <span class="text-ink">Auditor</span> files new tickets → back to <span class="text-ink">Planner</span> — the loop closes and the next cycle re-arms.
        </p>
      </div>
    </section>

    <!-- Modes -->
    <section class="mx-auto max-w-5xl px-6 pb-16">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-muted">Seven session modes</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          modes.map((mode) => (
            <div class="rounded-xl border border-line bg-surface p-5">
              <span class="font-mono text-sm font-semibold text-accent">{mode.name}</span>
              <p class="mt-2 text-sm text-muted leading-relaxed">{mode.line}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Why teammates, not tools -->
    <section class="mx-auto max-w-5xl px-6 pb-16">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-muted">
        Why teammates, not tools
      </h2>
      <div class="mt-8 space-y-10">
        {
          differentiators.map((d, i) => (
            <div class="grid items-center gap-6 sm:grid-cols-2">
              <div class={i % 2 === 1 ? 'sm:order-2' : ''}>
                <h3 class="text-xl font-semibold text-ink">{d.heading}</h3>
                <p class="mt-2 text-muted leading-relaxed">{d.body}</p>
              </div>
              <div class={i % 2 === 1 ? 'sm:order-1' : ''}>
                <div class="rounded-xl border border-line bg-surface-soft p-5">
                  <div class="flex flex-col gap-1.5 font-mono text-sm text-muted">
                    {d.diagram.map((row) => (
                      <span>{row}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Terminal snippet: the single real command excerpt -->
    <section class="mx-auto max-w-5xl px-6 pb-16">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-muted">See it run</h2>
      <div class="prose mt-6 max-w-none">
        <pre><code>{`$ cd ~/projects/acme-api
$ adhoc                       # one agent: claim → implement → PR → notify

[mux] session acme-api_adhoc_claude ready
[mux] next-work → implement #142
      … plans, edits, runs the tests …
[mux] opened PR #143 · notified you`}</code></pre>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="mx-auto max-w-5xl px-6 pb-24">
      <div class="rounded-2xl border border-line bg-surface-soft p-8 sm:p-10">
        <h2 class="text-2xl font-bold text-ink">Ready to hand off the busywork?</h2>
        <p class="mt-2 max-w-2xl text-muted">
          My AI Team ships as part of the bundle — {bundlePriceSummary} (USD).
        </p>
        <a
          href="/pricing"
          class="mt-6 inline-flex items-center rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-accent-hover"
        >
          See pricing &amp; get the bundle
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
